    </div>
</section>

<!-- ======================= community-Section ======================== -->
<section class="community-section">
    <div class="container">
        <div class="comm-section-header">
            <div class="comm-header-titles">
                <span class="comm-subtitle">GROWING TOGETHER</span>
                <h2 class="comm-title">From the Community</h2>
            </div>
            <a asp-controller="Post" asp-action="Feed" class="comm-view-all">
                See All Posts <i class="fa-solid fa-chevron-right"></i>
            </a>
        </div>

        <div class="comm-grid">


            
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="cta-content">
        <h2 class="cta-title">Ready to Grow?</h2>
        <p class="cta-description">
            Join thousands of farmers and gardeners sharing their love for
            growing.
        </p>
        <div class="cta-btns">
            <a asp-controller="Account" asp-action="Login" class="btn btn-cta-yellow">Get Started Free</a>
            <a asp-controller="Product" asp-action="MarketPlace" class="btn btn-cta-dark">Browse Market</a>
        </div>
    </div>
</section>