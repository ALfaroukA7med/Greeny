@using Greeny.BLL.ModelVM.Post
@using System.Security.Claims
@* @model PostDetailsVM *@


@{
    ViewData["Title"] = "Home Page";
    Layout = "_Layout";
}

<section class="hero-section">
    <div class="overlay"></div>

    <div class="hero-content">
        <h1 class="main-title">
            Where Farms <br />
            <span class="highlight">Meet Community</span>
        </h1>

        <p class="description">
            Buy directly from our marketplace, discover gardening tips, and
            connect with a community that loves growing things.
        </p>

        <div class="hero-btns">
            <button class="btn btn-primary">
                <i class="fa-solid fa-bag-shopping"></i>
                <a asp-controller="Product" asp-action="MarketPlace"> Shop the Market </a>
            </button>
            <button class="btn btn-secondary">
                <i class="fa-solid fa-user-group"></i>
                <a asp-controller="Post" asp-action="Feed"> Join the Community </a>
            </button>
        </div>

        @* <div class="stats-container">
            <div class="stat-box">
                <h3 class="stat-number">120+</h3>
                <p class="stat-label">Local Farmers</p>
            </div>
