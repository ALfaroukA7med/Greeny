                <p class="stat-label">Products</p>
            </div>
            <div class="stat-box">
                <h3 class="stat-number">8,500+</h3>
                <p class="stat-label">Community Members</p>
            </div>
        </div> *@
    </div>
</section>

<!-- ======================= Products-Section ======================== -->

<section class="products-section">
    <div class="container">
        <div class="section-header">
            <div class="header-titles">
                <span class="subtitle">FRESH PICKS</span>
                <h2 class="title">Featured Products</h2>
            </div>
            <a asp-controller="Product" asp-action="MarketPlace" class="view-all">
                View All <i class="fa-solid fa-chevron-right"></i>
            </a>
        </div>

        <div class="product-grid">
            <article class="product-card">
                <div class="card-image">
                    <img src="https://images.unsplash.com/photo-1592924357228-91a4daadcfea?auto=format&fit=crop&q=80&w=800"
                         alt="Tomatoes" />
                    <span class="badge badge-left badge-vegetables">Vegetables</span>
                    <span class="badge badge-right badge-organic">Organic</span>
                </div>
                <div class="card-content">
                    <div class="rating">
                        <i class="fa-solid fa-star"></i> <span class="score">4.9</span>
                        <span class="reviews">(128)</span>
                    </div>
                    <h3 class="product-title">Organic Vine Tomatoes</h3>
                    <div class="meta-info">
                        <span><i class="fa-solid fa-circle-user"></i> Marcus Green</span>
                        <span>
                            <i class="fa-solid fa-location-dot"></i> Riverside
                            Valley
                        </span>
                    </div>
                    <div class="card-footer">
                        <div class="price">
                            <span class="amount">$4.99</span>
                            <span class="unit">per kg</span>
                        </div>
                        <button class="add-btn">
                            <i class="fa-solid fa-cart-shopping"></i> Add
                        </button>
                    </div>
                </div>
            </article>
            <article class="product-card">
                <div class="card-image">
                    <img src="https://images.unsplash.com/photo-1592924357228-91a4daadcfea?auto=format&fit=crop&q=80&w=800"
                         alt="Tomatoes" />
                    <span class="badge badge-left badge-vegetables">Vegetables</span>
