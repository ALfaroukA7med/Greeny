@using Greeny.BLL.ModelVM.ProductVM
@model DetailsProductVM




<section class="product-details-section">
    <div class="container">
                
        <a asp-action="MarketPlace" asp-controller="Product" class="back-link"><i class="fa-solid fa-arrow-left"></i> Back</a>

        <div class="product-details-layout">
            <div class="product-image-wrapper">
               <img src="~/media/photos/product-tomatoes.jpg" />
            </div>

            <div class="product-info-wrapper">

                <h1 class="pd-title"> @Model.Name </h1>
                <div class="pd-rating">
                    <div class="stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Floor(Model.averageRating))
                            {
                                <i class="fas fa-star text-warning"></i>
                            }
                            else if (i - (double)Model.averageRating < 1 && i > (double)Model.averageRating)
                            {
                                <i class="fas fa-star-half-alt text-warning"></i>
                            }
                            else
                            {
                                <i class="far fa-star text-muted"></i>
                            }
                        }
                    </div>
                    <span class="score">@Model.averageRating.ToString("0.0")</span>
                    <span class="reviews">( @Model.totalReviews  reviews)</span>
                </div>

                <div class="pd-price">$ @Model.Price <span>per kg</span></div>

                <p class="pd-description"> @Model.Description </p>

                <div class="pd-stock">
                    <i class="fa-regular fa-circle-check"></i> @Model.Quantity in Stock
                </div>

                <div class="pd-actions-row">
                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                        <input type="hidden" name="productId" value="@Model.Id" />
        
                        <div class="pd-actions-row">
                            <div class="pd-qty-wrapper">
                                <span class="qty-label">Quantity</span>
                                <div class="qty-control">
                                    <button type="button" class="qty-btn" id="pd-minus">
                                        <i class="fa-solid fa-minus"></i>
                                    </button>
                
                                    <input type="number" name="quantity" class="qty-value" id="pd-qty" value="1" min="1" readonly />
                
                                    <button type="button" class="qty-btn" id="pd-plus">
                                        <i class="fa-solid fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="pd-buttons">
                            <button type="submit" class="btn-add-to-cart">
                                <i class="fa-solid fa-cart-shopping"></i> Add to Cart
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="product-reviews-section">
    <div class="container">
        <h2 class="reviews-section-title">Customer Reviews</h2>

        <div class="reviews-layout">
            <div class="reviews-summary-column">
                <div class="rating-summary">
                    <span class="big-rating">@Model.averageRating</span>
                    <div class="stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Floor(Model.averageRating))
                            {
                                <i class="fas fa-star text-warning"></i>
                            }
                            else if (i - (double)Model.averageRating < 1 && i > (double)Model.averageRating)
                            {
                                <i class="fas fa-star-half-alt text-warning"></i>
                            }
                            else
                            {
                                <i class="far fa-star text-muted"></i>
                            }
                        }
                    </div>
                    <span>@Model.averageRating.ToString("0.0")</span>
                    <span class="review-count"> based on @Model.totalReviews  reviews</span>
                </div>

                <div class="add-review-box">
                    <h3>Write a Review</h3>
                            
                    <form asp-controller="Review" asp-action="Create" method="post" id="reviewForm" class="review-form">

        
                        <input type="hidden" name="Stars" id="ratingsValue" value="0" />
        
                        <div class="star-rating-input">
                            <i class="fa-regular fa-star" data-rating="1"></i>
                            <i class="fa-regular fa-star" data-rating="2"></i>
                            <i class="fa-regular fa-star" data-rating="3"></i>
                            <i class="fa-regular fa-star" data-rating="4"></i>
                            <i class="fa-regular fa-star" data-rating="5"></i>
                        </div>

                        <textarea name="Content" placeholder="Share your thoughts about this product..." required></textarea>
        
                        <button type="submit" class="btn-submit-review">
                            Submit Review
                        </button>
                    </form>
                </div>
            </div>

                    

            <div class="reviews-list-column">

                @foreach (var review in @Model.Reviews)
                {
                    <div class="review-card">

                        <div class="review-header">
                            <img src="@review.UserImage"
                                 class="reviewer-avatar" />
                            <div class="review-user">

                                <div class="reviewer-info">

                                    <h4>@review.UserName</h4>

                                    <span class="review-date">
                                        @review.Date.ToString("MMMM d, yyyy")
                                    </span>

                                </div>

                            </div>

                            <div class="review-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Math.Floor(Model.averageRating))
                                    {
                                        <i class="fas fa-star text-warning"></i>
                                    }
                                    else if (i - (double)Model.averageRating < 1 && i > (double)Model.averageRating)
                                    {
                                        <i class="fas fa-star-half-alt text-warning"></i>
                                    }
                                    else
                                    {
                                        <i class="far fa-star text-muted"></i>
                                    }
                                }

                            </div>

                        </div>

                        <p class="review-text">
                            @review.Content
                        </p>

                    </div>
                }

                <button class="load-more-reviews">
                    Load More Reviews
                </button>

            </div>
        </div>
    </div>
</section>

<button id="scrollTopBtn" class="scroll-top-btn" title="Go to top">
    <i class="fa-solid fa-arrow-up"></i>
</button>

@section Styles {

    <link rel="stylesheet" href="~/css/master.css" />
    <link rel="stylesheet" href="~/css/product.css" />

}

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/product.js"></script>
    <script src="~/js/market.js"></script>

    <script>

        const qtyInput = document.getElementById('pd-qty');
        const plusBtn = document.getElementById('pd-plus');
        const minusBtn = document.getElementById('pd-minus');

        const maxAvailable = @Model.Quantity;

        plusBtn.addEventListener('click', () => {

            let currentVal = parseInt(qtyInput.value);

            if (currentVal < maxAvailable) {

                qtyInput.value = currentVal + 1;

            } else {

                alert("Sorry, only " + maxAvailable + " items are available.");
            }
        });

        minusBtn.addEventListener('click', () => {

            let currentVal = parseInt(qtyInput.value);

            if (currentVal > 1) {

                qtyInput.value = currentVal - 1;
            }
        });

    </script>

    <script>

        document.addEventListener("DOMContentLoaded", function () {

            const stars =
            document.querySelectorAll('.star-rating-input i');

            const ratingsInput =
            document.getElementById('ratingsValue');

            stars.forEach(star => {

                star.addEventListener('click', function () {

                    const rating =
                    this.getAttribute('data-rating');

                    ratingsInput.value = rating;

                    stars.forEach(s => {

                        if (s.getAttribute('data-rating') <= rating)
                        {
                            s.classList.remove('fa-regular');

                            s.classList.add('fa-solid');

                            s.style.color = "#ffc107";
                        }
                        else
                        {
                            s.classList.remove('fa-solid');

                            s.classList.add('fa-regular');

                            s.style.color = "#ccc";
                        }

                    });

                });

            });

        });

    </script>

}