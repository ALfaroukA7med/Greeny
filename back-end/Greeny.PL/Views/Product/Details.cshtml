@using Greeny.BLL.ModelVM.ProductVM
@model DetailsProductVM

<section class="product-details-section">
    <div class="container">

        <a asp-action="MarketPlace" asp-controller="Product" class="back-link"><i class="fa-solid fa-arrow-left"></i> Back</a>

        <div class="product-details-layout">
            <div class="product-image-wrapper">
                <img src="~/Files/@Model.Image" />
            </div>

            <div class="product-info-wrapper">

                <h1 class="pd-title"> @Model.Name </h1>
                <div class="pd-rating">
                    <div class="stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Floor(Model.averageRating))
                            {
                                <i class="fas fa-star text-warning"></i>
                            }
                            else if (i - (double)Model.averageRating < 1 && i > (double)Model.averageRating)
                            {
                                <i class="fas fa-star-half-alt text-warning"></i>
                            }
                            else
                            {
                                <i class="far fa-star text-muted"></i>
                            }
                        }
                    </div>
                    <span class="score">@Model.averageRating.ToString("0.0")</span>
                    <span class="reviews">( @Model.totalReviews  reviews)</span>
                </div>

                <div class="pd-price">$ @Model.Price <span>per kg</span></div>

                <p class="pd-description"> @Model.Description </p>

                <div class="pd-stock">
                    <i class="fa-regular fa-circle-check"></i> @Model.Quantity in Stock
                </div>

                <div class="pd-actions-row">
                    <form asp-controller="Cart" asp-action="Create" method="post">
                        <input type="hidden" name="productId" value="@Model.Id" />

                        <div class="pd-actions-row">
                            <div class="pd-qty-wrapper">
                                <span class="qty-label">Quantity</span>
                                <div class="qty-control">
                                    <button type="button" class="qty-btn" id="pd-minus">
                                        <i class="fa-solid fa-minus"></i>
                                    </button>

                                    <input type="number" name="quantity" class="qty-value" id="pd-qty" value="1" min="1" readonly />

                                    <button type="button" class="qty-btn" id="pd-plus">
                                        <i class="fa-solid fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="pd-buttons">
                            <button type="submit" class="btn-add-to-cart">
                                <i class="fa-solid fa-cart-shopping"></i> Add to Cart
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="product-reviews-section">
    <div class="container">

        <h2 class="reviews-section-title">
            Customer Reviews
        </h2>

        <div class="reviews-layout">

            <div class="reviews-summary-column">

                <div class="rating-summary">

                    <span class="big-rating">
                        @Model.averageRating.ToString("0.0")
                    </span>

                    <div class="stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Floor(Model.averageRating))
                            {
                                <i class="fas fa-star text-warning"></i>
                            }
                            else if (i - Model.averageRating < 1 && i > Model.averageRating)
                            {
                                <i class="fas fa-star-half-alt text-warning"></i>
                            }
                            else
                            {
                                <i class="far fa-star text-muted"></i>
                            }
                        }
                    </div>

                    <span class="rating-value">
                        @((Model.Reviews != null && Model.Reviews.Any()) ? Model.averageRating.ToString("0.0") : "0.0")
                    </span>

                    <span class="review-count">
                        based on @Model.totalReviews reviews
                    </span>

                </div>

                @if (TempData["Success"] != null)
                {
                    <div class="review-alert-success">
                        <i class="fa-solid fa-circle-check"></i>
                        @TempData["Success"]
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="review-alert-error">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        @TempData["Error"]
                    </div>
                }

                <div class="add-review-box">

                    <h3>Write a Review</h3>

                    <form asp-controller="Review"
                          asp-action="Create"
                          method="post"
                          id="reviewForm"
                          class="review-form">

                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="ProductId"
                               value="@Model.Id" />

                        <input type="hidden"
                               name="Stars"
                               id="ratingsValue"
                               value="0" />

                        <div class="review-stars-input-wrapper">
                            <label class="review-label">Your Rating</label>
                            <div class="star-rating-input">
                                <i class="fa-regular fa-star" data-rating="1"></i>
                                <i class="fa-regular fa-star" data-rating="2"></i>
                                <i class="fa-regular fa-star" data-rating="3"></i>
                                <i class="fa-regular fa-star" data-rating="4"></i>
                                <i class="fa-regular fa-star" data-rating="5"></i>
                            </div>
                        </div>

                        <div class="review-textarea-wrapper">
                            <label class="review-label">Your Review</label>
                            <textarea name="Content"
                                      placeholder="Share your thoughts about this product..."
                                      required></textarea>
                        </div>

                        <button type="submit" class="btn-submit-review">
                            <i class="fa-solid fa-paper-plane"></i> Submit Review
                        </button>

                    </form>

                </div>

            </div>

            <div class="reviews-list-column">

                @if (Model.Reviews != null && Model.Reviews.Any())
                {
                    @foreach (var review in Model.Reviews.OrderByDescending(r => r.Date))
                    {
                        <div class="review-card">
                            <div class="review-header">
                                <div class="review-user">
                                    <img src="~/Files/@review.UserImage" class="reviewer-avatar" />
                                    <div class="reviewer-info">
                                        <h4>@review.UserName</h4>
                                        <span class="review-date">
                                            @review.Date.ToString("MMMM d, yyyy")
                                        </span>
                                    </div>
                                </div>

                                <div class="review-stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= review.Stars)
                                        {
                                            <i class="fas fa-star text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="far fa-star text-muted"></i>
                                        }
                                    }
                                </div>
                            </div>

                            <p class="review-text">
                                @review.Content
                            </p>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-reviews">
                        <i class="fa-regular fa-comments"></i>
                        <h3>No Reviews Yet</h3>
                        <p>Be the first to review this product.</p>
                    </div>
                }

            </div>

        </div>
    </div>
</section>

<button id="scrollTopBtn" class="scroll-top-btn" title="Go to top">
    <i class="fa-solid fa-arrow-up"></i>
</button>

@section Styles {
    <link rel="stylesheet" href="~/css/master.css" />
    <link rel="stylesheet" href="~/css/product.css" />

    <style>
        /* إضافة ستايلات التنبيهات المفقودة للحفاظ على جمالية الواجهة */
        .review-alert-success, .review-alert-error {
            padding: 16px 18px;
            border-radius: 16px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
        }

        .review-alert-success {
            background: #dcfce7;
            color: #166534;
        }

        .review-alert-error {
            background: #fee2e2;
            color: #991b1b;
        }

        .star-rating-input i {
            cursor: pointer;
            transition: 0.2s;
            color: #ccc;
        }

            .star-rating-input i.active {
                color: #ffc107 !important;
            }
    </style>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/product.js"></script>
    <script src="~/js/market.js"></script>

    <script>
        // كود التحكم في الكمية
        const qtyInput = document.getElementById('pd-qty');
        const plusBtn = document.getElementById('pd-plus');
        const minusBtn = document.getElementById('pd-minus');
        const maxAvailable = @Model.Quantity;

        plusBtn.addEventListener('click', () => {
        let currentVal = parseInt(qtyInput.value);
        if (currentVal < maxAvailable) {
        qtyInput.value = currentVal + 1;
        } else {
        alert("Sorry, only " + maxAvailable + " items are available.");
        }
        });

        minusBtn.addEventListener('click', () => {
        let currentVal = parseInt(qtyInput.value);
        if (currentVal > 1) {
        qtyInput.value = currentVal - 1;
        }
        });
    </script>

    <script>
        // كود إدخال وتلوين النجوم الديناميكي التفاعلي المحسّن
        document.addEventListener("DOMContentLoaded", function () {
        const stars = document.querySelectorAll(".star-rating-input i");
        const ratingInput = document.getElementById("ratingsValue");
        let selectedRating = 0;

        stars.forEach(star => {
        star.addEventListener("mouseenter", function () {
        highlightStars(this.dataset.rating);
        });

        star.addEventListener("mouseleave", function () {
        highlightStars(selectedRating);
        });

        star.addEventListener("click", function () {
        selectedRating = this.dataset.rating;
        ratingInput.value = selectedRating;
        highlightStars(selectedRating);
        });
        });

        function highlightStars(rating) {
        stars.forEach(star => {
        if (parseInt(star.dataset.rating) <= parseInt(rating)) {
        star.classList.add("active", "fa-solid");
        star.classList.remove("fa-regular");
        } else {
        star.classList.remove("active", "fa-solid");
        star.classList.add("fa-regular");
        }
        });
        }

        document.getElementById("reviewForm").addEventListener("submit", function (e) {
        if (ratingInput.value == "0") {
        e.preventDefault();
        alert("Please select a rating before submitting.");
        }
        });
        });
    </script>
}