@model IEnumerable<Greeny.BLL.ModelVM.ReferencePlanet.DetailsRefPlanetVM>

@{
    ViewData["Title"] = "Index";
}


<div class="plants-container">

    <h1 class="plants-title">
        🌱 Reference Plants
    </h1>

    <div class="plants-grid">

        @foreach (var item in Model)
        {
            <div class="plant-card">

                <div class="plant-image">
                    <img src="~/Files/@item.Image" alt="@item.CommonName" />
                </div>

                <div class="plant-content">

                    <h2 class="plant-name">
                        @item.CommonName
                    </h2>

                    <p class="plant-description">
                        @item.ShortDescription
                    </p>

                    <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="read-more-btn">
                        Read Article
                    </a>

                </div>

            </div>
        }

    </div>

</div>



@section Styles {
    <style>
        body {
            background: #f4f9f4;
            font-family: 'Segoe UI', sans-serif;
        }

        .plants-container {
            width: 90%;
            margin: 40px auto;
        }

        .plants-title {
            text-align: center;
            font-size: 40px;
            font-weight: bold;
            color: #2d6a4f;
            margin-bottom: 40px;
        }

        .plants-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }

        .plant-card {
            background: #fff;
            border-radius: 22px;
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            transition: 0.4s ease;
            position: relative;
        }

            .plant-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 18px 35px rgba(0,0,0,0.15);
            }

        .plant-image {
            width: 100%;
            height: 250px;
            overflow: hidden;
        }

            .plant-image img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: 0.5s;
            }

        .plant-card:hover .plant-image img {
            transform: scale(1.08);
        }

        .plant-content {
            padding: 22px;
        }

        .plant-name {
            font-size: 24px;
            font-weight: bold;
            color: #1b4332;
            margin-bottom: 12px;
        }

        .plant-description {
            color: #555;
            line-height: 1.7;
            margin-bottom: 20px;
            min-height: 70px;
        }

        .read-more-btn {
            display: inline-block;
            padding: 12px 22px;
            background: #40916c;
            color: white;
            border-radius: 12px;
            text-decoration: none;
            transition: 0.3s;
            font-weight: 600;
        }

            .read-more-btn:hover {
                background: #2d6a4f;
                color: white;
            }


        .plants-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        /* Tablet */
        @@media (max-width: 992px) {
            .plants-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        /* Mobile */
        @@media (max-width: 600px) {
            .plants-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}