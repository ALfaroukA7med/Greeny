@model IEnumerable<Greeny.BLL.ModelVM.ReferencePlanet.DetailsForDashboard>

@{
    Layout = "_DashBoardLayout";
}


    <header class="topbar">
        <div>
            <h1>Planets</h1>
            <p>Manage all planets dashboard</p>
        </div>

        <div class="topbar-actions">
            <a asp-controller="ReferencePlanet" asp-action="Create" class="add-btn">
                <i class="fa-solid fa-plus"></i>
                Add Planet
            </a>
        </div>
    </header>

    <section class="table-section">

        <div class="section-header">

            <h2>Planets List</h2>

            <div class="filters">
                <div class="search-wrapper">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" placeholder="Search planet..." class="search-input">
                </div>
            </div>

        </div>

        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Common Name</th>
                    <th>Planet Type</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody id="productsTable">

                @foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.Id</td>
                        <td>@item.CommonName</td>
                        <td>@item.PlanetType</td>

                        <td>
                           <div class="action-buttons">

    <a asp-action="Edit"
       asp-route-id="@item.Id"
       class="btn btn-edit">
        Edit
    </a>

    <form asp-action="Delete"
          method="post"
          style="display:inline;"
          onsubmit="return confirm('Are you sure you want to delete this user?');">

        <input type="hidden" name="id" value="@item.Id" />

        <button type="submit" class="btn btn-delete">
            Delete
        </button>

    </form>

</div>
                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </section>



     @section Styles{
             <link rel="stylesheet" href="~/css/dashboard.css" />
         <style>

          
        .action-buttons {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        /* Base button */
        .btn {
            padding: 8px 14px;
            border-radius: 8px;
            border: none;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.25s ease;
            text-decoration: none;
            display: inline-block;
        }

        /* 🟢 Edit Button */
        .btn-edit {
            background-color: #22c55e; /* green */
            color: white;
        }

            .btn-edit:hover {
                background-color: #16a34a;
                transform: translateY(-2px);
                box-shadow: 0 6px 12px rgba(34, 197, 94, 0.3);
            }

        /* 🔴 Delete Button */
        .btn-delete {
            background-color: #ef4444; /* red */
            color: white;
        }

            .btn-delete:hover {
                background-color: #dc2626;
                transform: translateY(-2px);
                box-shadow: 0 6px 12px rgba(239, 68, 68, 0.3);
            }

        /* click animation */
        .btn:active {
            transform: scale(0.95);
        }

    </style>
}

    @section Scripts{
            <script src="~/js/dashboard.js"></script>
    }