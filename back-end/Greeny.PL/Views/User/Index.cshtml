@model List<Greeny.BLL.ModelVM.User.DetailsUserVM>
@{
    Layout = "_DashBoardLayout";
    ViewData["Title"] = "Index";
}


        <header class="topbar">

            <div>
                <h1>Users</h1>
                <p>Manage all registered users</p>
            </div>
        <div class="topbar-actions">
            <a asp-controller="Role" asp-action="RegisterWithRole" class="add-btn">
                <i class="fa-solid fa-plus"></i>
                Add User With Role
            </a>
        </div>
        </header>

    <section class="cards">

        <div class="card">
            <div class="card-icon customers-icon">
                <i class="fa-solid fa-users"></i>
            </div>
            <div>
                <h3>Total Users</h3>
                <h2>@ViewBag.All</h2>
            </div>
        </div>

        <div class="card">
            <div class="card-icon products-icon">
                <i class="fa-solid fa-user-check"></i>
            </div>
            <div>
                <h3>Active</h3>
                <h2>@ViewBag.Active</h2>
            </div>
        </div>

        <div class="card">
            <div class="card-icon orders-icon">
                <i class="fa-solid fa-user-slash"></i>
            </div>
            <div>
                <h3>Inactive</h3>
                <h2>@(ViewBag.All - ViewBag.Active)</h2>
            </div>
        </div>

    </section>


        <section class="table-section">

            <div class="section-header">

                <h2>Users List</h2>

            </div>

            <table>

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Active</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>#@item.Id</td>
                            <td>@item.FirstName @item.LastName</td>
                            <td>@item.Email</td>
                            <td>
                                @if (item.IsDeleted)
                                {
                                    <span class="status canceled">No</span>
                                }
                                else
                                {
                                    <span class="status completed">Yes</span>
                                }
                            </td>

                            <td class="action-buttons">

                                <!-- Delete -->
                                <form asp-action="Delete"
                                      asp-route-id="@item.Id"
                                      method="post"
                                      style="display:inline;"
                                      onsubmit="return confirm('Are you sure you want to delete this user?');">

                                    <button type="submit" class="btn btn-delete">
                                        Delete
                                    </button>

                                </form>

                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </section>



@section Styles{
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <style>
        .btn {
            padding: 6px 12px;
            border-radius: 6px;
            text-decoration: none;
            color: white;
            font-size: 13px;
            transition: 0.25s;
            border: none;
            cursor: pointer;
        }

        /* Details */
        .btn-details {
            background: #3b82f6;
        }

            .btn-details:hover {
                background: #2563eb;
                transform: translateY(-2px);
            }

        /* Delete */
        .btn-delete {
            background: #ef4444;
        }

            .btn-delete:hover {
                background: #dc2626;
                transform: translateY(-2px);
            }

        /* Status */
        .status {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            color: white;
        }

        .completed {
            background: #22c55e;
        }

        .canceled {
            background: #ef4444;
        }


        table th,
        table td {
            text-align: center;
            vertical-align: middle;
        }

        table tbody tr {
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

            table tbody tr:hover {
                background-color: #f8f9fa;
            }

        table th:not(:last-child),
        table td:not(:last-child) {
            border-right: 1px solid rgba(0,0,0,0.08);
        }
    </style>
}

@section Scripts{
    <script src="~/js/dashboard.js"></script>
}