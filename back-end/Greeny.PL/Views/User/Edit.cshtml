@model Greeny.BLL.ModelVM.User.UpdateUserVM

@{
    ViewData["Title"] = "Edit User";
}

<div class="agri-container">

    <div class="agri-card">

        <div class="agri-header">
            <h2>🌿 Edit User Profile</h2>
            <p>Update user information and profile image</p>
        </div>

        <form asp-action="Edit" method="post" enctype="multipart/form-data">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input asp-for="Id" type="hidden" />

            <!-- First Name -->
            <div class="form-group agri-group">
                <label asp-for="FirstName"></label>
                <input asp-for="FirstName" class="form-control agri-input" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>

            <!-- Last Name -->
            <div class="form-group agri-group">
                <label asp-for="LastName"></label>
                <input asp-for="LastName" class="form-control agri-input" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>

            <!-- Phone -->
            <div class="form-group agri-group">
                <label asp-for="PhoneNumber"></label>
                <input asp-for="PhoneNumber" class="form-control agri-input" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>

            <!-- Address -->
            <div class="form-group agri-group">
                <label asp-for="Address"></label>
                <input asp-for="Address" class="form-control agri-input" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <div class="agri-image-box">
                <label>Current Profile Image</label>

                <img id="previewImg"
                     src="@Url.Content("~/Files/" + Model.ProfilePicture)"
                     class="agri-img"
                     onerror="this.src='@Url.Content("~/images/default-user.png")'" />
            </div>

            <!-- Upload New Image -->
            <div class="form-group agri-group">
                <label for="PictureInput" class="file-label">
                    📤 Upload New Profile Image (click here)
                </label>

                <input asp-for="Picture"
                       type="file"
                       id="PictureInput"
                       accept="image/*"
                       hidden />

                <span asp-validation-for="Picture" class="text-danger"></span>
            </div>

             
            <!-- Submit -->
            <button type="submit" class="agri-btn">
                🌱 Save Changes
            </button>

        </form>

    </div>

</div>

@section Styles {

    <style>

        body {
            background: #f4f9f4;
            font-family: 'Segoe UI', sans-serif;
        }

        .agri-group label {
            display: inline-block;
            margin-bottom: 6px;
            font-weight: 600;
            color: #1b5e20;
            font-size: 14px;
        }

        .file-label {
            display: block;
            padding: 10px;
            background: #e8f5e9;
            border: 1px dashed #2e7d32;
            border-radius: 10px;
            text-align: center;
            cursor: pointer;
            color: #2e7d32;
            transition: 0.3s;
        }

            .file-label:hover {
                background: #c8e6c9;
            }

        .agri-container {
            display: flex;
            justify-content: center;
            padding: 40px 15px;
        }

        .agri-card {
            width: 100%;
            max-width: 500px;
            background: #ffffff;
            border-radius: 18px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            padding: 25px;
            border-top: 5px solid #2e7d32;
        }

        .agri-header {
            text-align: center;
            margin-bottom: 20px;
        }

            .agri-header h2 {
                color: #2e7d32;
                margin-bottom: 5px;
            }

            .agri-header p {
                color: #777;
                font-size: 14px;
            }

        .agri-group {
            margin-bottom: 15px;
        }

        .agri-input {
            border-radius: 10px;
            border: 1px solid #c8e6c9;
            padding: 10px;
            transition: 0.3s;
        }

            .agri-input:focus {
                border-color: #2e7d32;
                box-shadow: 0 0 8px rgba(46,125,50,0.2);
            }

        .agri-image-box {
            text-align: center;
            margin: 15px 0;
            padding: 10px;
            border: 1px dashed #a5d6a7;
            border-radius: 12px;
            background: #f9fff9;
        }

        .agri-img {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #2e7d32;
            margin-top: 10px;
        }

        .no-image {
            color: #999;
            font-size: 14px;
            margin-top: 10px;
        }

        .agri-btn {
            width: 100%;
            padding: 12px;
            background: #2e7d32;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            transition: 0.3s;
            cursor: pointer;
        }

            .agri-btn:hover {
                background: #1b5e20;
            }

    </style>

}



@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const input = document.getElementById("PictureInput");
            const img = document.getElementById("previewImg");
            const noImage = document.getElementById("noImageText");

            input.addEventListener("change", function (event) {

                const file = event.target.files[0];

                if (file) {
                    const reader = new FileReader();

                    reader.onload = function (e) {
                        img.src = e.target.result;
                        img.style.display = "block";

                        if (noImage) {
                            noImage.style.display = "none";
                        }
                    };

                    reader.readAsDataURL(file);
                }
            });

        });
    </script>
}