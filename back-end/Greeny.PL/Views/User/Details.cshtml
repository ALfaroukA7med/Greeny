@model Greeny.BLL.ModelVM.User.DetailsUserVM

@{
    ViewData["Title"] = "Profile";
}


<div class="profile-container">

    <!-- Header -->
    <div class="profile-header">

        <img class="profile-img"
             src="@(string.IsNullOrEmpty(Model.ProfilePicture)
                                         ? Url.Content("~/images/default-user.png")
                                         : Url.Content("~/Files/" + Model.ProfilePicture))"
             onerror="this.src='/images/default-user.png'" />

        <h2>@Model.FirstName @Model.LastName</h2>
    </div>

    <!-- Body -->
    <div class="profile-body">

        @* <div class="profile-item">
            <label>ID</label>
            <span>@Model.Id</span>
        </div> *@

        <div class="profile-item">
            <label>Phone</label>
            <span>@Model.PhoneNumber</span>
        </div>

        <div class="profile-item">
            <label>Email</label>
            <span>@Model.Email</span>
        </div>

        <div class="profile-item">
            <label>Address</label>
            <span>@Model.Address</span>
        </div>

    </div>

    <!-- Actions -->
    <div class="profile-actions">
        <a class="btn-edit"
               asp-action="Edit"
               asp-route-id="@Model.Id">
            Edit
        </a>

        <form asp-action="Delete"
              method="post"
              style="display:inline;"
              onsubmit="return confirm('Are you sure you want to delete this user?');">

            <input type="hidden" name="id" value="@Model.Id" />

            <button type="submit" class="btn btn-danger">
                Delete
            </button>
        </form>

        <a class="btn-back"
               asp-controller="Home"
               asp-action="Index">
            Back
        </a>
    </div>
</div>



@section Styles {
    <style>
        body {
            background: #f4f9f4;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .profile-container {
            max-width: 850px;
            margin: 40px auto;
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            overflow: hidden;
        }

        .profile-header {
            background: linear-gradient(135deg, #2e7d32, #66bb6a);
            padding: 30px;
            text-align: center;
            color: white;
        }

        .profile-img {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 4px solid white;
            object-fit: cover;
            margin-bottom: 10px;
        }

        .profile-header h2 {
            margin: 10px 0 0;
        }

        .profile-body {
            padding: 25px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .profile-item {
            background: #f8fbf8;
            padding: 15px;
            border-radius: 10px;
            border-left: 5px solid #43a047;
        }

            .profile-item label {
                font-weight: bold;
                color: #2e7d32;
                display: block;
                margin-bottom: 5px;
            }

            .profile-item span {
                color: #333;
            }

        .profile-actions {
            padding: 20px;
            text-align: center;
            border-top: 1px solid #eee;
        }

        .btn-edit {
            background: #43a047;
            color: white;
            padding: 10px 18px;
            border-radius: 8px;
            text-decoration: none;
            margin-right: 10px;
        }

            .btn-edit:hover {
                background: #2e7d32;
            }

        .btn-back {
            background: #e0e0e0;
            color: #333;
            padding: 10px 18px;
            border-radius: 8px;
            text-decoration: none;
        }

            .btn-back:hover {
                background: #cfcfcf;
            }


        .btn-delete {
            background: #e53935;
            color: white;
            padding: 10px 18px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
        }

            .btn-delete:hover {
                background: #c62828;
            }
    </style>
}


@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const card = document.querySelector(".profile-container");

            card.style.opacity = 0;
            card.style.transform = "translateY(20px)";

            setTimeout(() => {
                card.style.transition = "0.6s ease";
                card.style.opacity = 1;
                card.style.transform = "translateY(0)";
            }, 100);

        });
    </script>
}