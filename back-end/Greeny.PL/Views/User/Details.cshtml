@model Greeny.BLL.ModelVM.User.DetailsUserVM

@{
    ViewData["Title"] = "Profile";
}


<div class="profile-container">

    <!-- Header -->
    <div class="profile-header">

        <img class="profile-img"
             src="@(string.IsNullOrEmpty(Model.ProfilePicture)
                                         ? Url.Content("~/images/default-user.png")
                                         : Url.Content("~/Files/" + Model.ProfilePicture))"
             onerror="this.src='/images/default-user.png'" />

        <h2>@Model.FirstName @Model.LastName</h2>
    </div>

    <!-- Body -->
    <div class="profile-body">

        @* <div class="profile-item">
            <label>ID</label>
            <span>@Model.Id</span>
        </div> *@

        <div class="profile-item">
            <label>Phone</label>
            <span>@Model.PhoneNumber</span>
        </div>

        <div class="profile-item">
            <label>Email</label>
            <span>@Model.Email</span>
        </div>

        <div class="profile-item">
            <label>Address</label>
            <span>@Model.Address</span>
        </div>

    </div>

    <!-- Actions -->
    <div class="profile-actions">
        <a class="btn-edit"
               asp-action="Edit"
               asp-route-id="@Model.Id">
            Edit
        </a>

        <form asp-action="Delete"
              method="post"
              style="display:inline;"
              onsubmit="return confirm('Are you sure you want to delete this user?');">

            <input type="hidden" name="id" value="@Model.Id" />

            <button type="submit" class="btn btn-danger">
                Delete
            </button>
        </form>

        <a class="btn-back"
               asp-controller="Home"
               asp-action="Index">
            Back
        </a>
    </div>
</div>



@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" />
}


@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const card = document.querySelector(".profile-container");

            card.style.opacity = 0;
            card.style.transform = "translateY(20px)";

            setTimeout(() => {
                card.style.transition = "0.6s ease";
                card.style.opacity = 1;
                card.style.transform = "translateY(0)";
            }, 100);

        });
    </script>
}