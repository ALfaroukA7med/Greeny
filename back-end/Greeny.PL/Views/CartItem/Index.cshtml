@using Greeny.BLL.ModelVM.CartItem
@model IEnumerable<DetailsCartItemVM>

@{
    ViewData["Title"] = "Cart Items";

    decimal grandTotal = 0;
}

<div class="container mt-5">

    <h2 class="fw-bold mb-4">
        Shopping Cart
    </h2>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">

            Cart is empty

        </div>
    }
    else
    {

        <table class="table table-bordered text-center align-middle">

            <thead class="table-dark">

                <tr>

                    <th>Image</th>
                    <th>Product</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Total</th>
                    <th>Actions</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    var total = item.Price * item.Quantity;

                    grandTotal += total;

                    <tr>

                        <td>

                            <img src="@item.ImageUrl"
                                 width="80"
                                 height="80"
                                 class="rounded" />

                        </td>

                        <td>

                            @item.ProductName

                        </td>

                        <td>

                            @item.CategoryName

                        </td>

                        <td>

                            $@item.Price

                        </td>

                        <td>

                            <div class="d-flex justify-content-center align-items-center gap-2">

                                <a asp-action="Decrease"
                                       asp-route-id="@item.Id"
                                       asp-route-cartId="1"
                                       class="btn btn-warning btn-sm">

                                    -

                                </a>

                                <span class="fw-bold">

                                    @item.Quantity

                                </span>

                                <a asp-action="Increase"
                                       asp-route-id="@item.Id"
                                       asp-route-cartId="1"
                                       class="btn btn-success btn-sm">

                                    +

                                </a>

                            </div>

                        </td>

                        <td class="fw-bold text-success">

                            $@total

                        </td>

                        <td>

                            <form asp-action="Delete"
                                  method="post">

                                <input type="hidden"
                                       name="id"
                                       value="@item.Id" />

                                <input type="hidden"
                                       name="cartId"
                                       value="1" />

                                <button type="submit"
                                        class="btn btn-danger btn-sm">

                                    Remove

                                </button>

                            </form>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

        <div class="text-end mt-4">

            <h4>

                Grand Total :

                <span class="text-success fw-bold">

                    $@grandTotal

                </span>

            </h4>

        </div>

    }

</div>