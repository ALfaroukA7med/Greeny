@model List<Microsoft.AspNetCore.Identity.IdentityRole>

@{
    Layout = "_DashBoardLayout";
    ViewData["Title"] = "All Roles";
}

<header class="topbar">

    <div>
        <h1>Roles</h1>
        <p>Manage system roles</p>
    </div>
    <div class="topbar-actions">
        <a asp-controller="Role" asp-action="AddRole" class="add-btn">
            <i class="fa-solid fa-plus"></i>
            Add User With Role
        </a>
    </div>
</header>

<section class="table-section">

    <div class="section-header">
        <h2>Roles List</h2>
    </div>

    <table>

        <thead>
            <tr>
                <th>ID</th>
                <th>Role Name</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var role in Model)
            {
                <tr>

                    <td>
                        @role.Id
                    </td>

                    <td>
                        <span class="status completed">
                            @role.Name
                        </span>
                    </td>

                    <td>

                        <form asp-action="DeleteRole"
                              method="post"
                              style="display:inline;">

                            <input type="hidden" name="id" value="@role.Id" />

                            <button type="submit"
                                    class="btn btn-delete"
                                    onclick="return confirm('Are you sure you want to delete this role?')">

                                Delete

                            </button>

                        </form>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</section>

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <style>
        .btn {
            padding: 6px 12px;
            border-radius: 6px;
            text-decoration: none;
            color: white;
            font-size: 13px;
            transition: 0.25s;
            border: none;
            cursor: pointer;
        }

        /* Details */
        .btn-details {
            background: #3b82f6;
        }

            .btn-details:hover {
                background: #2563eb;
                transform: translateY(-2px);
            }

        /* Delete */
        .btn-delete {
            background: #ef4444;
        }

            .btn-delete:hover {
                background: #dc2626;
                transform: translateY(-2px);
            }

        /* Status */
        .status {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            color: white;
        }

        .completed {
            background: #22c55e;
        }

        .canceled {
            background: #ef4444;
        }


        table th,
        table td {
            text-align: center;
            vertical-align: middle;
        }

        table tbody tr {
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

            table tbody tr:hover {
                background-color: #f8f9fa;
            }

        table th:not(:last-child),
        table td:not(:last-child) {
            border-right: 1px solid rgba(0,0,0,0.08);
        }
    </style>
}

@section Scripts {
    <script src="~/js/dashboard.js"></script>
}
