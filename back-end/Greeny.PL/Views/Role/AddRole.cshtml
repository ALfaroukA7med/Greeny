@model Greeny.BLL.ModelVM.AuthVM.RoleVM

@{
    Layout = "_DashBoardLayout";
    ViewData["Title"] = "Add Role";
}

<div class="form-side">

    <h2 class="form-title">
        🌿 Add New Role
    </h2>

    @if (ViewBag.Success != null)
    {
        <div class="success-msg">
            ✅ @ViewBag.Success
        </div>
    }

    <form asp-action="SaveRole" method="post">

        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="form-group">

            <label asp-for="RoleName"></label>

            <input asp-for="RoleName"
                   class="form-control"
                   placeholder="Enter role name..." />

            <span asp-validation-for="RoleName" class="text-danger"></span>

        </div>

        <button type="submit" class="submit-btn">
            🌱 Create Role
        </button>

    </form>

    <a asp-action="Index" class="back-link">
        ← Back to Roles List
    </a>

</div>


@section Styles{
    <link rel="stylesheet" href="~/css/dashboard.css" />
<style>
.form-side {
padding: 40px;
/* max-width: 500px;
margin: 50px auto;
background: #fff;
border-radius: 24px;
box-shadow: 0 12px 30px rgba(0,0,0,0.08); */
}

.form-title {
color: #2d6a4f;
font-size: 32px;
font-weight: bold;
margin-bottom: 30px;
text-align: center;
}

.form-group {
margin-bottom: 20px;
}

.form-group label {
font-weight: 600;
color: #1b4332;
margin-bottom: 8px;
display: block;
}

.form-control {
width: 100%;
border-radius: 12px;
border: 1px solid #d8e2dc;
padding: 14px;
transition: .3s;
font-size: 15px;
}

.form-control:focus {
border-color: #40916c;
box-shadow: 0 0 0 4px rgba(64,145,108,.15);
outline: none;
}

.submit-btn {
width: 100%;
border: none;
padding: 15px;
border-radius: 14px;
background: linear-gradient(to right, #40916c, #2d6a4f);
color: white;
font-size: 18px;
font-weight: bold;
transition: .3s;
}

.submit-btn:hover {
transform: translateY(-3px);
box-shadow: 0 10px 20px rgba(45,106,79,.25);
}

.back-link {
display: block;
margin-top: 20px;
text-align: center;
text-decoration: none;
color: #2d6a4f;
font-weight: 600;
}

.success-msg {
background: #e8f5e9;
color: #2e7d32;
padding: 12px;
border-radius: 12px;
margin-bottom: 15px;
text-align: center;
font-weight: 600;
}
</style>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/dashboard.js"></script>
}