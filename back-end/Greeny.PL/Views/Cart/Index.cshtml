@using Greeny.BLL.ModelVM.Cart
@model CartDetailsVM

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container mt-5">

    <h2 class="fw-bold mb-4">
        Shopping Cart
    </h2>

    @if (!Model.Items.Any())
    {
        <div class="alert alert-warning text-center">

            Your cart is empty

        </div>
    }
    else
    {

        <table class="table table-bordered align-middle text-center">

            <thead class="table-dark">

                <tr>

                    <th>Image</th>
                    <th>Product</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Total</th>
                    <th>Actions</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model.Items)
                {
                    var total = item.Price * item.Quantity;

                    <tr>

                        <!-- Image -->

                        <td>

                            <img src="@item.ImageUrl"
                                 width="80"
                                 height="80"
                                 class="rounded" />

                        </td>

                        <!-- Product -->

                        <td>

                            @item.ProductName

                        </td>

                        <!-- Category -->

                        <td>

                            @item.CategoryName

                        </td>

                        <!-- Price -->

                        <td>

                            $@item.Price

                        </td>

                        <!-- Quantity -->

                        <td>

                            <div class="d-flex justify-content-center align-items-center gap-2">

                                <!-- Decrease -->

                                <a asp-controller="CartItem"
                                       asp-action="Decrease"
                                       asp-route-id="@item.Id"
                                       class="btn btn-warning btn-sm">

                                    -

                                </a>

                                <span class="fw-bold">

                                    @item.Quantity

                                </span>

                                <!-- Increase -->

                                <a asp-controller="CartItem"
                                       asp-action="Increase"
                                       asp-route-id="@item.Id"
                                       class="btn btn-success btn-sm">

                                    +

                                </a>

                            </div>

                        </td>

                        <!-- Total -->

                        <td class="fw-bold text-success">

                            $@total

                        </td>

                        <!-- Delete -->

                        <td>

                            <form asp-controller="CartItem"
                                  asp-action="Delete"
                                  method="post">

                                <input type="hidden"
                                       name="id"
                                       value="@item.Id" />

                                <button type="submit"
                                        class="btn btn-danger btn-sm">

                                    Remove

                                </button>

                            </form>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

        <!-- Cart Total -->

        <div class="text-end mt-4">

            <h4>

                Grand Total :

                <span class="text-success fw-bold">

                    $@Model.Total

                </span>

            </h4>

        </div>

    }

</div>