
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Greeny Dashboard</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap"
          rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <link rel="stylesheet" href="~/css/dashboard.css" />
    @RenderSection("Styles", required: false)

</head>

<body>

    <div class="dashboard">

        <!-- Sidebar -->
        <aside class="sidebar">

            <div class="logo">
                <i class="fa-solid fa-leaf"></i>
                <h2>Greeny</h2>
            </div>

            <nav class="sidebar-nav">

                <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                    <i class="fa-solid fa-chart-line"></i>
                    Dashboard
                </a>

                <a class="nav-link" asp-controller="Product" asp-action="Index">
                    <i class="fa-solid fa-box"></i>
                    Products
                </a>
                <a class="nav-link" asp-controller="ReferencePlanet" asp-action="IndexForDashboard">
                    <i class="fa-solid fa-leaf"></i>
                    Reference Planet
                </a>

                <a class="nav-link" asp-controller="User" asp-action="Index">
                    <i class="fa-solid fa-users"></i>
                    Users
                </a>
                <a class="nav-link" asp-controller="Role" asp-action="Index">
                    <i class="fa-solid fa-users"></i>
                    Roles
                </a>

                <a class="nav-link" asp-controller="Orders" asp-action="Index">
                    <i class="fa-solid fa-cart-shopping"></i>
                    Orders
                </a>


                <a class="nav-link" asp-controller="Posts" asp-action="Index">
                    <i class="fa-solid fa-newspaper"></i>
                    Posts
                </a>

                <a class="nav-link" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-home"></i>
                    Back To Home
                </a>

            </nav>

        </aside>

        <!-- Main -->
        <main class="main-content">

        
            @RenderBody()

        </main>

    </div>

    <script src="~/js/dashboard.js"></script>
    @RenderSection("Scripts", required: false)

</body>

</html>