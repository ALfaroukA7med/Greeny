<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Greeny @ViewBag.Title </title>
    <link rel="stylesheet" href="css/master.css" />
    <link rel="stylesheet" href="css/community.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@700&display=swap"
          rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>

<body>
    <nav>
        <a class="left-nav" href="index.html">
            <img src="..\media\photos\Transparent Greeny leaf.png" alt="logo" />
            <p class="greeny">greeny</p>
        </a>
        <div class="middle-nav">
            <a href="index.html" class="active-link">home</a>
            <a href="market.html">marketplace</a>
            <a href="community.html">community</a>
            <a href="refrence.html">refrence</a>
        </div>
        <div class="right-nav">
            <a href="cart.html" title="Go to Cart" class="cart-icon-container">
                <img src="../media/photos/cart.png" alt="Cart" />
                <span class="cart-badge">0</span>
            </a>
            <a class="logIn" href="log.html">log in</a>
            <a class="signUp" href="log.html?tab=register">sign up</a>

            <div class="hamburger" title="Menu ">
                <div></div>
                <div></div>
                <div></div>
            </div>
        </div>
    </nav>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="footer-container">
            <div class="footer-brand">
                <a class="footer-logo" href="index.html">
                    <img src="..\media\photos\Transparent Greeny leaf.png" alt="Greeny Logo" />
                    <span class="greeny-text">greeny</span>
                </a>
                <p class="footer-description">
                    Connecting farmers and communities for a greener, more sustainable
                    world.
                </p>
            </div>
        </div>

        <div class="footer-bottom">
            <p>&copy; 2026 Greeny. Made with 🌱</p>
        </div>
    </footer>
    <button id="scrollTopBtn" class="scroll-top-btn" title="Go to top">
        <i class="fa-solid fa-arrow-up"></i>
    </button>
    <script src="js/community.js"></script>
    <script src="js/script.js"></script>
</body>

</html>