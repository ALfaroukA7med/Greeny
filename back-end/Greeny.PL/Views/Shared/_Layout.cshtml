@using Greeny.DAL.Entities
@using Microsoft.AspNetCore.Identity
@inject UserManager<User> UserManager

@{
    var user = await UserManager.GetUserAsync(User);
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>Greeny</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/css/master.css" />
    <link rel="stylesheet" href="~/css/community.css">
    <link rel="stylesheet" href="~/css/market.css">
    <link rel="stylesheet" href="~/css/refrence.css">
    <link rel="stylesheet" href="~/css/master.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@700&display=swap"
          rel="stylesheet" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    @RenderSection("Styles", required: false)
</head>


<body>

    <nav>
        <a class="left-nav" asp-controller="Home" asp-action="Index">
            <img src="~/media/photos/Transparent Greeny leaf.png" alt="logo" />
            <p class="greeny">greeny</p>
        </a>
        <div class="middle-nav">
            <a asp-controller="Home" asp-action="Index" class="active-link">home</a>
            <a asp-controller="Product" asp-action="MarketPlace">marketplace</a>
            <a asp-controller="Post" asp-action="Feed">community</a>
            <a asp-controller="ReferencePlanet" asp-action="Index">refrence</a>
        </div>

        <div class="right-nav">
            <div class="notification-wrapper">
                <a href="#" class="bell-button">
                    <i class="fa-regular fa-bell"></i>
                    <span class="notif-badge">2</span>
                </a>

                <div class="notification-dropdown">
                    <div class="notif-header">Notifications</div>

                    <div class="notif-item unread">
                        <div class="notif-icon">👤</div>
                        <div class="notif-details">
                            <p>Someone commented to your blog.</p>
                            <span class="notif-time">10mins ago.</span>
                        </div>
                        <div class="clear-fix"></div>
                    </div>

                    <div class="notif-item">
                        <div class="notif-icon">🛒</div>
                        <div class="notif-details">
                            <p>New statue update to your order.</p>
                            <span class="notif-time">2hrs ago.</span>
                        </div>
                        <div class="clear-fix"></div>
                    </div>

                    <div class="notif-footer">
                        <a href="notifications.html">Show All</a>
                    </div>
                </div>
            </div>
            <a href="cart" title="Go to Cart" class="cart-icon-container">
                <img src="~/media/photos/cart.png" alt="Cart">
                <span class="cart-badge">0</span>
            </a>
            @if (User.Identity.IsAuthenticated)
            {
                <div class="user-profile-wrapper">
                    <button class="profile-dropdown-btn" id="profile-dropdown-btn">
                        <img src="@(string.IsNullOrEmpty(user?.ProfilePicture)
                                ? Url.Content("~/media/photos/default-user.jpg")
                              : Url.Content("~/Files/" + user.ProfilePicture))"
                             class="profile-avatar" />
                        <span class="profile-name">@user?.FirstName @user?.LastName</span>
                        <i class="fa-solid fa-chevron-down profile-chevron"></i>
                    </button>

                    <div class="profile-menu" id="profile-menu">
                        <a asp-controller="User" asp-action="Details" asp-route-id="@user?.Id" class="profile-menu-item">
                            <i class="fa-regular fa-user"></i>
                            My Profile
                        </a>

                        <div class="profile-menu-divider"></div>

                        <form asp-controller="Account" asp-action="SignOut" method="post">
                            <button type="submit" class="profile-menu-item logout-item">
                                <i class="fa-solid fa-arrow-right-from-bracket"></i>
                                SignOut
                            </button>
                        </form>

                    </div>
                </div>
            }
            else
            {
                <!-- Login / Register -->
                <div class="sign-bottoms">
                    <a class="logIn" asp-controller="Account" asp-action="Login">
                        Login
                    </a>

                    <a class="signUp" asp-controller="Account" asp-action="Register">
                        Register
                    </a>
                </div>
            }
      
            <div class="hamburger" title="Menu ">
                <div></div>
                <div></div>
                <div></div>
          
            </div>
        
        </div>

    </nav>
     
    <div class="menu">
      <a href="index.html" class="active-link">home</a>
      <a href="market.html">marketplace</a>
      <a href="community.html">community</a>
      <a href="refrence.html">refrence</a>
      <a href="profile.html">profile</a>
      <a href="logIn.html" class="logIn">log in</a>
      <a href="signUp.html" class="signUp">join us</a>
    </div>

    @RenderBody()

    <footer class="site-footer">
        <div class="footer-container">
            <div class="footer-brand">
                <a class="footer-logo" href="index.html">
                    <img src="~/media/photos/Transparent Greeny leaf.png" alt="logo" />
                    <span class="greeny-text">greeny</span>
                </a>
                <p class="footer-description">
                    Connecting farmers and communities for a greener, more sustainable world.
                </p>
            </div>
        </div>

        <div class="footer-bottom">
            <p>&copy; 2026 Greeny. Made with 🌱</p>
        </div>
    </footer>

    <button id="scrollTopBtn" class="scroll-top-btn" title="Go to top">
        <i class="fa-solid fa-arrow-up"></i>
    </button>


    <script src="~/js/community.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/script.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>