@using Greeny.BLL.ModelVM.Category
@model IEnumerable<DetailsCategoryVM>

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Categories";
}

<div class="categories-page">

    <!-- Header -->
    <div class="categories-header">
        <div>
            <h1>Categories</h1>
            <p>Manage all marketplace categories</p>
        </div>

        <a asp-action="Create" asp-controller="Category" class="add-btn">
            <i class="fa-solid fa-plus"></i>
            Add Category
        </a>
    </div>

    <!-- Categories Card -->
    <div class="categories-card">


        <!-- Table -->
        <div class="table-responsive">
            <table class="categories-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Icon</th>
                        <th>Name</th>
                        <th>Products Count</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody id="categoriesTable">

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>#@item.Id</td>

                            <td>
                                <img src="~/Files/@item.Icon"
                                     class="category-icon"
                                     alt="icon" />
                            </td>

                            <td>@item.Name</td>

                            <td>
                                <span class="count-badge">
                                    @item.NumberOfProducts
                                </span>
                            </td>

                            <!-- Actions -->
                            <td>
                                <div class="actions">

                                    <!-- Edit -->
                                    <a asp-action="Edit" asp-controller="Category"
                                       asp-route-id="@item.Id"
                                       class="action-btn edit-btn">

                                        <i class="fa-solid fa-pen"></i>
                                    </a>

                                    <!-- Delete -->
                                    <form asp-action="Delete"
                                          asp-controller="Category"
                                          asp-route-id="@item.Id"
                                          method="post"
                                          style="display:inline;"
                                          onsubmit="return confirm('Are you sure you want to delete this category?');">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="action-btn delete-btn">

                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>

                                </div>
                            </td>

                        </tr>
                    }

                </tbody>
            </table>
        </div>

    </div>
</div>

@section Styles {

    <style>

        body {
            background: #f2f7f3;
            font-family: 'Segoe UI', sans-serif;
        }

        .categories-page {
            padding: 40px;
        }

        /* Header */

        .categories-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 35px;
        }

            .categories-header h1 {
                font-size: 52px;
                font-weight: bold;
                color: #0b3d2c;
                margin-bottom: 8px;
            }

            .categories-header p {
                color: #64748b;
                font-size: 20px;
            }

        .add-btn {
            background: #1f7a4c;
            color: white;
            padding: 16px 28px;
            border-radius: 18px;
            text-decoration: none;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: .3s;
            box-shadow: 0 10px 20px rgba(31,122,76,.15);
        }

            .add-btn:hover {
                transform: translateY(-2px);
                background: #16643d;
            }

        /* Card */

        .categories-card {
            background: white;
            border-radius: 32px;
            padding: 35px;
            box-shadow: 0 10px 25px rgba(0,0,0,.05);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

            .card-header h2 {
                font-size: 40px;
                color: #0b3d2c;
                font-weight: bold;
            }

        /* Search */

        .search-box {
            position: relative;
            width: 340px;
        }

            .search-box i {
                position: absolute;
                left: 18px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
            }

            .search-box input {
                width: 100%;
                padding: 16px 18px 16px 50px;
                border-radius: 18px;
                border: 1px solid #dbe4dc;
                outline: none;
                font-size: 16px;
            }

        /* Table */

        .categories-table {
            width: 100%;
            border-collapse: collapse;
        }

            .categories-table thead th {
                text-align: left;
                padding: 18px 10px;
                color: #64748b;
                font-size: 22px;
                border-bottom: 1px solid #e2e8f0;
            }

            .categories-table tbody td {
                padding: 18px 10px;
                font-size: 22px;
                border-bottom: 1px solid #edf2f7;
                color: #0f172a;
                vertical-align: middle;
            }

        /* Icon */

        .category-icon {
            width: 70px;
            height: 70px;
            object-fit: cover;
            border-radius: 16px;
            border: 2px solid #e2e8f0;
        }

        /* Count */

        .count-badge {
            background: #ecfdf3;
            color: #15803d;
            padding: 10px 18px;
            border-radius: 12px;
            font-weight: bold;
            font-size: 18px;
        }

        /* Actions */

        .actions {
            display: flex;
            gap: 12px;
        }

        .action-btn {
            width: 45px;
            height: 45px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            color: white;
            transition: .3s;
            border: none;
            cursor: pointer;
        }

            .action-btn:hover {
                transform: translateY(-2px);
            }

        .edit-btn {
            background: #0ea5e9;
        }

        .delete-btn {
            background: #ef4444;
        }

        /* Responsive */

        @@media(max-width:1100px) {

            .categories-header {
                flex-direction: column;
                gap: 20px;
                align-items: flex-start;
            }

            .card-header {
                flex-direction: column;
                gap: 20px;
                align-items: flex-start;
            }

            .search-box {
                width: 100%;
            }

            .table-responsive {
                overflow-x: auto;
            }
        }

    </style>
}

@section Scripts {

    <script>

        const searchInput = document.getElementById("searchInput");

        searchInput.addEventListener("keyup", function () {

            const filter = searchInput.value.toLowerCase();

            const rows = document.querySelectorAll("#categoriesTable tr");

            rows.forEach(row => {

                const text = row.innerText.toLowerCase();

                row.style.display = text.includes(filter)
                    ? ""
                    : "none";
            });

        });

    </script>
}