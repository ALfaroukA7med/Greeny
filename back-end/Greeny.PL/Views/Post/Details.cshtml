@using Greeny.BLL.ModelVM.Wrapper
@using Greeny.BLL.ModelVM.Post
@using System.Security.Claims

@model PostDetailsVM

<header class="comm-page-header">
    <div>
        <span class="comm-page-badge">GROWING TOGETHER</span>
        <h1 class="comm-page-title">Community Feed</h1>
        <p class="comm-page-desc">Share your garden journey with fellow growers</p>
    </div>
</header>

<div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 15px;">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger"
             style="padding: 12px; margin-bottom: 20px; border-radius: 8px; background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; width: 100%;">
            <i class="fa-solid fa-triangle-exclamation"></i> @TempData["ErrorMessage"]
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success"
             style="padding: 12px; margin-bottom: 20px; border-radius: 8px; background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; width: 100%;">
            <i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]
        </div>
    }
</div>

<div class="container"
     style="display: flex; flex-direction: column; gap: 16px; max-width: 650px; padding: 0 15px; margin: 20px auto;">

    @* 1. FORM TO CREATE A NEW POST *@

    @* 2. DISPLAY ALL POSTS *@
    @if (Model != null)
    {
        <article class="comm-card"
                    style="display: flex; flex-direction: row; width: 100%; margin: 0; padding: 0; overflow: hidden; background: #ffffff; border: 1px solid #e0e0e0; border-radius: 12px; box-sizing: border-box;">

            @* LEFT SIDEBAR: VOTING PANEL *@
            <div class="reddit-voting"
                    style="display: flex; flex-direction: column; align-items: center; width: 44px; background-color: #f8f9fa; padding: 12px 4px; gap: 4px; border-right: 1px solid #f1f1f1; flex-shrink: 0;">
                <form asp-controller="Vote" asp-action="UpVote" asp-route-id="@Model.Id" method="Model"
                        style="margin: 0; padding: 0;">
                    <button type="submit" class="vote-btn upvote"
                            style="background: none; border: none; color: #878a8c; cursor: pointer; padding: 4px; font-size: 1.2rem; transition: color 0.2s;"
                            onmouseover="this.style.color='#ff4500'" onmouseout="this.style.color='#878a8c'">
                        <i class="fa-solid fa-arrow-up"></i>
                    </button>
                </form>

                <span class="vote-score"
                        style="font-size: 0.85rem; font-weight: 700; color: #1a1a1b; min-width: 24px; text-align: center; font-family: sans-serif; margin: 2px 0;">
                    @Model.Votes
                </span>

                <form asp-controller="Vote" asp-action="DownVote" asp-route-id="@Model.Id" method="Model"
                        style="margin: 0; padding: 0;">
                    <button type="submit" class="vote-btn downvote"
                            style="background: none; border: none; color: #878a8c; cursor: pointer; padding: 4px; font-size: 1.2rem; transition: color 0.2s;"
                            onmouseover="this.style.color='#7193ff'" onmouseout="this.style.color='#878a8c'">
                        <i class="fa-solid fa-arrow-down"></i>
                    </button>
                </form>
            </div>

            @* RIGHT SIDEBAR: CONTENT, METADATA & COMMENTS PANEL *@
            <div style="display: flex; flex-direction: column; flex: 1; padding: 12px; box-sizing: border-box; min-width: 0;">

                @* User Header Info *@
                <div class="comm-card-header"
                        style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px; padding: 0; width: 100%;">
                    <img src="https://i.pravatar.cc/150?img=11" alt="@Model.AuthorName" class="comm-avatar"
                            style="width: 28px; height: 28px; border-radius: 50%;" />
                    <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 6px;">
                        <span class="comm-user-name"
                                style="font-weight: 600; font-size: 0.85rem; color: #1a1a1b;">@Model.AuthorName</span>
                        <span style="color: #7c7c7c; font-size: 0.8rem;">•</span>
                        <span class="comm-Model-date" style="color: #7c7c7c; font-size: 0.8rem;">@Model.FormattedDate</span>
                    </div>
                </div>

                @* Post Text Content *@
                <p class="comm-Model-text"
                        style="font-size: 0.95rem; color: #1a1a1b; line-height: 1.4; margin: 0 0 10px 0; word-break: break-word; text-align: left;">
                    @Model.Content
                </p>

                @* Post Image *@
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <div class="comm-card-image"
                            style="width: 100%; border-radius: 8px; overflow: hidden; margin-bottom: 10px; background-color: #f8f9fa;">
                        <img src="/@Model.ImagePath" class="comm-Model-img"
                                style="width: 100%; max-height: 380px; object-fit: cover; display: block;" />
                    </div>
                }

                @* Action Buttons (Comments Count & Delete) *@
                <div class="reddit-actions-bar"
                        style="display: flex; align-items: center; justify-content: space-between; width: 100%; border-top: 1px solid #f1f1f1; padding-top: 8px; margin-top: auto;">
                    <form asp-controller="Post" asp-action="Details" asp-route-id="@Model.Id" method="get">
                        <button type="submit" style="border: none; background: none;">
                            <div style="display: flex; align-items: center;">
                                <span class="comm-action"
                                        style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 10px; border-radius: 4px; cursor: pointer; color: #878a8c; font-size: 0.85rem; font-weight: 600; background-color: transparent; transition: background 0.1s;"
                                        onmouseover="this.style.backgroundColor='#f4f4f4'"
                                        onmouseout="this.style.backgroundColor='transparent'">
                                    <i class="fa-regular fa-comment" style="font-size: 1rem;"></i>
                                    <span>Comments (@(Model.Comments?.Count ?? 0))</span>
                                </span>
                            </div>
                        </button>
                    </form>

                    @if (User.Identity.IsAuthenticated && (User.FindFirstValue(ClaimTypes.NameIdentifier) == Model.UserId ||
            User.IsInRole("Admin")))
                    {
                        <form asp-controller="Post" asp-action="Delete" asp-route-id="@Model.Id" method="Post"
                                onsubmit="return confirm('Are you sure you want to delete this Model?');"
                                style="margin: 0; padding: 0; display: inline-flex;">
                            <button type="submit"
                                    style="background: none; border: none; color: #dc3545; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; font-size: 0.85rem; font-weight: 600; padding: 6px 10px; border-radius: 4px; font-family: inherit; transition: background 0.1s;"
                                    onmouseover="this.style.backgroundColor='#fff5f5'"
                                    onmouseout="this.style.backgroundColor='transparent'">
                                <i class="fa-regular fa-trash-can"></i>
                                <span>Delete</span>
                            </button>
                        </form>
                    }
                </div>

                @* --- New Comments Section --- *@
                <div class="comments-section" style="margin-top: 12px; border-top: 1px solid #f1f1f1; padding-top: 12px;">

                    @* Write Comment Form *@
                    @if (User.Identity.IsAuthenticated)
                    {
                        <form asp-controller="Comment" asp-action="Create" method="post"
                              style="display: flex; gap: 8px; margin-bottom: 12px; width: 100%;">
    
                            @* @Html.AntiForgeryToken() *@
    
                            <input type="hidden" name="NewComment.PostId" value="@Model.Id" />
                            <input type="text" asp-for="NewComment.Content" placeholder="Write a comment..." required
                                    style="flex: 1; padding: 8px 12px; border: 1px solid #e0e0e0; border-radius: 20px; font-size: 0.85rem; outline: none; font-family: inherit; transition: border-color 0.2s;" />
            
                            <button type="submit" style="background-color: #0079d3; color: white; border: none; padding: 6px 16px; border-radius: 20px; font-size: 0.85rem; font-weight: 600; cursor: pointer;">
                                Reply
                            </button>
                        </form>
                    }
                    else
                    {
                        <p style="font-size: 0.8rem; color: #7c7c7c; margin-bottom: 12px;">Log in to leave a comment.</p>
                    }

                    @* Display Comments List *@
                    @if (Model.Comments != null && Model.Comments.Count > 0)
                    {
                        <div class="comments-list"
                                style="display: flex; flex-direction: column; gap: 10px; max-height: 250px; overflow-y: auto; padding-right: 4px;">
                            @foreach (var comment in Model.Comments)
                            {
                                <div class="single-comment"
                                 style="background-color: #f8f9fa; padding: 8px 12px; border-radius: 8px; border-left: 2px solid #edeff1;">
    
                                <div class="comment-meta"
                                     style="display: flex; align-items: center; justify-content: space-between; gap: 6px; margin-bottom: 4px;">
        
                                    <div style="display: flex; align-items: center; gap: 6px;">
                                        <span style="font-weight: 600; font-size: 0.8rem; color: #1a1a1b;">@comment.AuthorName</span>
                                        <span style="color: #7c7c7c; font-size: 0.75rem;">•</span>
                                        <span style="color: #7c7c7c; font-size: 0.75rem;">@comment.TimeAgo</span>
                                    </div>

                                    @if (User.Identity.IsAuthenticated && (User.FindFirstValue(ClaimTypes.NameIdentifier) == comment.UserId || User.IsInRole("Admin")))
                                    {
                                        <form asp-controller="Comment" asp-action="Delete" method="post"
                                              onsubmit="return confirm('Are you sure you want to delete this comment?');" 
                                              style="margin: 0; padding: 0; display: inline;">
                                            @Html.AntiForgeryToken()
                
                                            <input type="hidden" name="id" value="@comment.Id" />
                                            <input type="hidden" name="postId" value="@Model.Id" />
                
                                            <button type="submit" 
                                                    style="background: none; border: none; color: #a3a3a3; cursor: pointer; font-size: 0.75rem; padding: 0; display: flex; align-items: center; gap: 4px; transition: color 0.1s;"
                                                    onmouseover="this.style.color='#dc3545'" 
                                                    onmouseout="this.style.color='#a3a3a3'">
                                                <i class="fa fa-trash"></i> Delete
                                            </button>
                                        </form>
                                    }
                                </div>

                                <p style="font-size: 0.85rem; color: #1a1a1b; margin: 0; line-height: 1.3; word-break: break-word; text-align: left;">
                                    @comment.Content
                                </p>
                            </div>
                            }
                        </div>
                    }
                </div>
                @* --- End of Comments Section --- *@

            </div> @* End of Right Sidebar *@
        </article> @* End of Post Article *@
    }
</div>