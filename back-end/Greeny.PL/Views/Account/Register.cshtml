@model Greeny.BLL.ModelVM.AuthVM.RegisterVM

@{
    ViewData["Title"] = "Register";
}

    <div class="auth-layout">
      <div class="auth-banner">
        <div class="auth-overlay"></div>
        <a class="sign-logo2" asp-controller="Home" asp-action="Index">
          <img
            src="~/media/photos/Transparent white greeny leaf.png"
            alt="logo"
          />
          <span class="greeny">greeny</span>
        </a>
        <div class="auth-quote-box">
          <h2 class="auth-quote">
            "Growing food is like printing your own money."
          </h2>
          <p class="auth-quote-sub">
            Join our community of farmers and gardening enthusiasts
          </p>
        </div>
      </div>

      <div class="auth-content">
        <div class="auth-form-container">
            <a class="sign-logo" asp-controller="Home" asp-action="Index">
            <img src="~/media/photos/Transparent Greeny leaf.png" alt="logo" />
            <span class="greeny">greeny</span>
          </a>
          <div class="auth-header">
            <h1>Welcome back</h1>
            <p>Sign in to continue to Greeny</p>
          </div>
            
                <form asp-action="SaveRegister" method="post" class="auth-form">               
                <div asp-validation-summary="All" class="text-danger"></div>


                    <div class="input-group FirstName">
                        <label asp-for="FirstName" class="control-label">First Name</label>
                        <div class="FirstName-wrapper">
                            <input type="text" asp-for="FirstName" class="form-control"
                         placeholder="Lorem ipsum dolor sit amet"/>
                        </div>
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="input-group LastName">
                        <label asp-for="LastName" class="control-label">Last Name</label>
                        <div class="LastName-wrapper">
                            <input type="text" asp-for="LastName" class="form-control"
                        placeholder="Lorem ipsum dolor sit amet" />
                        </div>
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>



            <div class="input-group">
                        <label asp-for="Email" class="control-label"></label>
                        <input asp-for="Email" class="form-control" type="email"
                         placeholder="lorem@example.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
            </div>


            <div class="input-group">
              <label asp-for="Password" class="control-label">Password</label>
              <div class="password-wrapper">
                <input asp-for="Password" class="form-control" type="password"
                  placeholder="••••••••••••••••" />
                  <i class="fa-regular fa-eye toggle-password" style="cursor:pointer;"></i>
              </div>
              <span asp-validation-for="Password" class="text-danger"></span>
            </div>


            <div class="input-group confirm-pass-group">
                        <label asp-for="ConfirmPassword" class="control-label">Confirm Password</label>
              <div class="password-wrapper">
              <input asp-for="ConfirmPassword" class="form-control" type="password"
              placeholder="••••••••••••••••" />
              <i class="fa-regular fa-eye toggle-password" style="cursor:pointer;"></i>
                    </div>
              <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="form-group">
                        <input type="submit" value="Register" class="auth-submit-btn" />
            </div>
                <a class="auth-tab" asp-controller="Account" asp-action="Login" style="color: black;">
                    Have Account , Login Here
                </a>

          </form>

        </div>
      </div>
    </div>


@section Styles {
    <link rel="stylesheet" href="~/css/master.css" />
    <link rel="stylesheet" href="~/css/log.css" />
}


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener("click", function(e){
            if(e.target.classList.contains("toggle-password")){

                const input = e.target.closest(".password-wrapper")
                                         .querySelector("input");

                if(input){
                    input.type = input.type === "password" ? "text" : "password";
                    e.target.classList.toggle("fa-eye");
                    e.target.classList.toggle("fa-eye-slash");
                }
            }
        });
    </script>

    @* <script src="~/js/signUp.js"></script>
    <script src="~/js/log.js"></script> *@
}

